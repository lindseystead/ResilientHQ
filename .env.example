# Firebase Configuration
# Get these from Firebase Console > Project Settings > Your apps > Web app
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key-here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id

# Application API Configuration
# Point this at your backend base URL. AI requests should be proxied server-side.
EXPO_PUBLIC_API_URL=https://api.example.com

# Safe open-source defaults
# Keep all AI features disabled unless you explicitly opt in.
EXPO_PUBLIC_AI_FEATURES_ENABLED=false
EXPO_PUBLIC_CHATBOT_ENABLED=false
EXPO_PUBLIC_JOURNAL_AI_ASSIST_ENABLED=false
EXPO_PUBLIC_COMMUNITY_AI_ASSIST_ENABLED=false
EXPO_PUBLIC_PROFILE_AI_BIO_ENABLED=false
EXPO_PUBLIC_AI_MOOD_SUGGESTIONS_ENABLED=false

# Local AI proxy (server runtime, not bundled into the client)
# Use these only when running `npm run server:ai-proxy` locally.
# OPENAI_API_KEY=your-openai-key
# AI_PROXY_REQUIRE_AUTH=true
# AI_PROXY_VERIFY_FIREBASE_TOKENS=true
# AI_PROXY_ENABLE_SEMANTIC_MODERATION=true
# AI_PROXY_OUTPUT_MODERATION_MODEL=omni-moderation-latest
# AI_PROXY_SEMANTIC_MODERATION_FAIL_CLOSED=true
# AI_PROXY_SEMANTIC_MODERATION_MIN_CHARS=240
# AI_PROXY_MAX_MESSAGES=60
# AI_PROXY_MAX_MESSAGE_CHARS=4000
# AI_PROXY_MAX_SYSTEM_MESSAGE_CHARS=8000
# AI_PROXY_RATE_LIMIT_STORE_PATH=./server/ai-proxy/rateLimitStore.js
# AI_PROXY_ALLOW_INSECURE_AUTH_IN_PRODUCTION=false
# AI_PROXY_ALLOW_MEMORY_RATE_LIMIT_IN_PRODUCTION=false

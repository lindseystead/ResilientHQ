{
  "name": "resilienthq",
  "main": "expo/AppEntry.js",
  "description": "Trauma-informed cross-platform resilience app built with Expo and React Native.",
  "version": "1.0.0",
  "author": "lindseystead",
  "license": "MIT",
  "homepage": "https://github.com/lindseystead/ResilientHQ#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/lindseystead/ResilientHQ.git"
  },
  "bugs": {
    "url": "https://github.com/lindseystead/ResilientHQ/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "shell-quote": "^1.9.0",
    "protobufjs": "^7.6.5"
  },
  "keywords": [
    "expo",
    "react-native",
    "resilience",
    "wellbeing",
    "mental-health"
  ],
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:simulator": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "web": "expo start --web",
    "server:ai-proxy": "node server/ai-proxy.js",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "lint:architecture": "node scripts/quality/check-feature-boundaries.js",
    "lint:cycles": "node scripts/quality/check-import-cycles.js",
    "lint:design": "node scripts/quality/check-design-tokens.js",
    "lint:firestore": "node scripts/quality/check-firestore-governance.js",
    "deps:check": "node scripts/quality/check-dependencies.js",
    "unused:files": "node scripts/quality/check-unused-files.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false --watchman=false",
    "coverage:ratchet": "node scripts/quality/check-coverage-ratchet.js",
    "e2e:maestro:smoke": "bash scripts/e2e/run-maestro-smoke.sh",
    "e2e:maestro:flow": "bash scripts/e2e/run-maestro-smoke.sh",
    "type-check": "tsc --noEmit",
    "verify": "npm run format:check && npm run lint && npm run lint:architecture && npm run lint:cycles && npm run lint:design && npm run lint:firestore && npm run deps:check && npm run unused:files && npm run type-check && npm run test:ci && npm run coverage:ratchet",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .prettierignore",
    "analyze": "npx expo export --platform web",
    "clean": "rm -rf node_modules ios/Pods ios/build && npm install && cd ios && pod install && cd ..",
    "clean:cache": "expo start --clear",
    "postinstall": "node scripts/postinstall.js",
    "precommit": "npm run lint && npm run lint:architecture && npm run lint:cycles && npm run lint:design && npm run lint:firestore && npm run type-check"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.7",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.8.4",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.10.0",
    "@sentry/react-native": "~7.2.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.28",
    "expo-constants": "~18.0.11",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "firebase": "^12.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1313.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.9",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.14",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": false
}
